# Copiaza acest fisier in ".env.local" (local) si seteaza acelasi valori
# in Railway > Variables (productie). Vezi README.md pentru pasii detaliati.

# Din Supabase Dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Din Supabase Dashboard > Project Settings > API > service_role (SECRET!)
# Folosit DOAR pe server (API routes), niciodata expus in browser.
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Adresa publica unde va fi gazduita aplicatia (fara "/" la final)
# Local: http://localhost:3000  |  Productie: https://numele-tau.up.railway.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Notificări prin email (opțional, dar recomandat) -----------------------
# Fără acestea, notificările apar doar în aplicație (clopoțelul din header),
# nu și pe email. Vezi README, secțiunea despre Resend.
RESEND_API_KEY=re_xxxxxxxxxx
EMAIL_FROM=notificari@breasla.ro

# --- Cloudflare Turnstile (anti-spam la înregistrare și autentificare) ------
# 1) Creează un widget pe dash.cloudflare.com > Turnstile — copiază Site Key
#    (pui aici) și Secret Key (NU aici — se pune în Supabase, vezi pasul 2).
# 2) Supabase Dashboard > Authentication > Bot and Abuse Protection >
#    Enable CAPTCHA protection > Cloudflare Turnstile > lipește Secret Key.
# Fără această variabilă, widgetul pur și simplu nu apare (util local) — dar
# dacă protecția e activată în Supabase fără cheia asta setată în producție,
# înregistrarea și login-ul vor eșua.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x4AAAAAAAxxxxxxxxxxxxxx
